@page "/admin/config"
@inject AdminService Admin

<div class="container-fluid p-4">
    <h1 class="mb-4">Configuration</h1>

    <div class="row g-3 mb-4">
        @foreach (var (name, agent) in agents)
        {
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        Agent: <strong>@name</strong>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm mb-0">
                            <tr>
                                <td class="text-muted" style="width: 120px;">Model</td>
                                <td>@agent.Model.Id</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Context</td>
                                <td>@agent.Model.ContextWindow.ToString("N0") tokens</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Tools</td>
                                <td>
                                    @foreach (var tool in agent.Tools)
                                    {
                                        <span class="badge bg-secondary me-1">@tool.Name</span>
                                    }
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card">
        <div class="card-header">config.yaml (secrets masked)</div>
        <div class="card-body p-0">
            <pre class="config-view mb-0">@rawConfig</pre>
        </div>
    </div>
</div>

@code {
    private IReadOnlyDictionary<string, AgentDefinition> agents = new Dictionary<string, AgentDefinition>();
    private string rawConfig = "";

    protected override async Task OnInitializedAsync()
    {
        agents = Admin.GetAgents();
        rawConfig = await Admin.GetRawConfigAsync();
    }
}
